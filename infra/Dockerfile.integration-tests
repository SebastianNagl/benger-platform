FROM python:3.11-slim

# Install system dependencies
RUN apt-get update && apt-get install -y \
    curl \
    postgresql-client \
    redis-tools \
    && rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /app

# Copy requirements for integration tests
COPY infra/tests/integration/requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

# Install additional testing dependencies
RUN pip install --no-cache-dir \
    pytest \
    pytest-asyncio \
    pytest-xdist \
    pytest-cov \
    requests \
    websockets \
    psycopg2-binary \
    redis \
    httpx

# Copy test files and service code for imports
COPY infra/tests/integration /infra/tests/integration
COPY services /services

# Set environment variables
ENV PYTHONPATH=/services/api:/services/workers:/services/frontend
ENV PYTEST_DISABLE_PLUGIN_AUTOLOAD=1

# Create test results directory
RUN mkdir -p /test_results

# Default command runs all integration tests
CMD ["pytest", "/infra/tests/integration", "-v", "--tb=short", "--maxfail=5"]