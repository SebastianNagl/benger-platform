# Without this file, the builder stage's `COPY . .` overwrites the
# node_modules freshly installed from package-lock.json with whatever the
# host happens to have (wrong platform binaries, drifted versions — e.g. a
# host next 15.5.18 clobbering the image's 15.5.19 crashes `next build`).
node_modules
.next
# Host env files must never leak into image builds — .env.local can carry
# machine-local toggles (e.g. NEXT_PRIVATE_LOCAL_WEBPACK) and secrets.
.env*
!.env.example
out
coverage
test-results
playwright-report
e2e/.auth
npm-debug.log*
.DS_Store
