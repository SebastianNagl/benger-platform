# Frontend Service Environment Configuration
# Dev defaults. Copy to .env.local and edit. Never use these values in production.

# =============================================================================
# Environment Identity
# =============================================================================
NODE_ENV=development

# =============================================================================
# Next.js Configuration
# =============================================================================
# DO NOT set NEXT_PUBLIC_API_URL for development - use proxy instead!
# This allows frontend dev server to proxy to Docker backend
NEXT_PUBLIC_ANNOTATION_SYSTEM=native

# =============================================================================
# Development Optimizations
# =============================================================================
NEXT_PRIVATE_LOCAL_WEBPACK=1
NEXT_PRIVATE_SKIP_SIZE_LIMIT_CHECK=1
WATCHPACK_POLLING=true
CHOKIDAR_USEPOLLING=true
CHOKIDAR_INTERVAL=2000
WATCHPACK_POLLING_INTERVAL=2000

# =============================================================================
# Next.js Development Settings
# =============================================================================
NEXT_TELEMETRY_DISABLED=1
NEXT_BUILD_OUTPUT_TRACE=false
NEXT_PUBLIC_REACT_STRICT_MODE=false

# =============================================================================
# Development Auth Settings
# =============================================================================
# Auto-login enabled for development (set to 'false' when testing registration/login flows)
NEXT_PUBLIC_ENABLE_DEV_AUTH=true

# =============================================================================
# Feature Flags (Frontend)
# =============================================================================
FEATURE_FLAGS_DEBUG=true

# =============================================================================
# Development URLs (Comments for reference)
# =============================================================================
# Frontend: http://localhost:3000 (dev server)
# Frontend (Docker): http://benger.localhost (through Traefik)
# API: proxied through Next.js dev server to Docker backend
