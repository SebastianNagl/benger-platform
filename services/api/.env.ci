# CI Environment Configuration for GitHub Actions
TESTING=true
ENVIRONMENT=test

# Database Configuration (GitHub Actions)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/test_benger
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=test_benger

# Redis Configuration (GitHub Actions)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# Celery Configuration (GitHub Actions)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Security Configuration (Test Values)
SECRET_KEY=test-secret-key-for-ci-environment
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Label Studio Configuration removed - using native annotation system

# Development Settings
DEBUG=false

# CORS (Test Values)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# File Upload
MAX_FILE_SIZE_MB=100
UPLOAD_DIR=./uploads

# API Keys (Mock Values for CI)
OPENAI_API_KEY=sk-test-key-for-ci
ANTHROPIC_API_KEY=sk-ant-test-key-for-ci
GOOGLE_API_KEY=test-google-key-for-ci
DEEPINFRA_API_KEY=test-deepinfra-key-for-ci 