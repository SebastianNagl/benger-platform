[flake8]
# Disable line length checks completely
max-line-length = 999999
ignore = E203, W503, E501
exclude = 
    .git,
    __pycache__,
    .venv,
    venv,
    alembic/versions,
    htmlcov,
    .pytest_cache,
    build,
    dist
per-file-ignores =
    # Allow longer lines in specific contexts where it's reasonable
    main.py:E501 