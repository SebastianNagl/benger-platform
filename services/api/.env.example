# API Service Environment Configuration
# Dev defaults. Copy to .env and edit. Never use these values in production.

# =============================================================================
# Environment Identity
# =============================================================================
ENVIRONMENT=development
DEBUG=true

# =============================================================================
# Database Configuration
# =============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=dev-password-123
POSTGRES_DB=benger
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URI=postgresql://postgres:dev-password-123@db:5432/benger

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=dev-redis-123
REDIS_URI=redis://:dev-redis-123@redis:6379/0

# =============================================================================
# Celery Configuration
# =============================================================================
CELERY_BROKER_URL=redis://:dev-redis-123@redis:6379/0
CELERY_RESULT_BACKEND=redis://:dev-redis-123@redis:6379/0

# =============================================================================
# Security Settings
# =============================================================================
JWT_SECRET_KEY=dev-jwt-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# =============================================================================
# Email Configuration (SendGrid HTTP API)
# =============================================================================
# Email is sent via the SendGrid HTTP API, not SMTP. Leave SENDGRID_API_KEY
# empty in development — messages are logged instead of sent. Set it to a real
# key (SG.…) to actually deliver mail.
SENDGRID_API_KEY=
EMAIL_FROM_ADDRESS=BenGER Notifications <notifications@benger.example>

# Templates default to /shared/email_templates/email (a single canonical
# directory used by both the API and the workers). Override for tests or
# if you keep custom templates somewhere else.
# EMAIL_TEMPLATE_DIR=/shared/email_templates/email

# =============================================================================
# Feature Flags Configuration
# =============================================================================
FEATURE_FLAGS_ENABLED=true
FEATURE_FLAGS_CACHE_TTL=300
FEATURE_FLAGS_DEBUG=true

# =============================================================================
# Logging Configuration
# =============================================================================
LOG_LEVEL=DEBUG
LOG_FORMAT=json

# =============================================================================
# Performance Settings
# =============================================================================
ANNOTATION_CACHE_TTL=3600
ANNOTATION_WEBSOCKET_ENABLED=true

# =============================================================================
# API Configuration
# =============================================================================
API_BASE_URL=http://api.localhost
ROOT_PATH=""

# LLM provider API keys (OPENAI_API_KEY, ANTHROPIC_API_KEY, GOOGLE_API_KEY,
# DEEPINFRA_API_KEY) are configured per-organization in the app UI, not here.
