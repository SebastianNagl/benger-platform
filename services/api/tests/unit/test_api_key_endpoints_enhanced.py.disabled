    # Provider-specific tests
    def test_all_supported_providers(self, client, auth_headers):
        """Test that all supported providers work with new error format"""
        providers = ["openai", "anthropic", "google", "deepinfra"]
        
        for provider in providers:
            with patch.object(user_api_key_service, 'validate_api_key', 
                            return_value=(True, f"Connection to {provider} successful", "success")):
                response = client.post(
                    f"/api/users/api-keys/{provider}/test",
                    json={"api_key": "test-key"},
                    headers=auth_headers["admin"]
                )
                    
            assert response.status_code == 200
            data = response.json()
            assert data["status"] == "success"
            assert data["error_type"] is None

    def test_error_type_consistency_across_providers(self, client, auth_headers):
        """Test that error types are consistent across all providers"""
        providers = ["openai", "anthropic", "google", "deepinfra"]
        error_types = ["auth", "timeout", "network", "quota", "unknown"]
        
        for provider in providers:
            for error_type in error_types:
                test_message = f"Test {error_type} error"
                is_valid = error_type == "quota"  # Quota errors should still show as valid
                
                with patch.object(user_api_key_service, 'validate_api_key', 
                                return_value=(is_valid, test_message, error_type)):
                    response = client.post(
                        f"/api/users/api-keys/{provider}/test",
                        json={"api_key": "test-key"},
                        headers=auth_headers["admin"]
                    )
                        
                assert response.status_code == 200
                        data = response.json()
                        expected_status = "success" if is_valid else "error"
                assert data["status"] == expected_status
                assert data["message"] == test_message
                        if expected_status == "error":
                            assert data["error_type"] == error_type
                        else:
                            assert data["error_type"] is None

    # Response format validation
    def test_response_format_structure(self, client, auth_headers):
        """Test that response format is consistent and complete"""
            with patch.object(user_api_key_service, 'validate_api_key', 
                        return_value=(False, "Test error", "auth")):
        response = client.post(
                "/api/users/api-keys/openai/test",
                json={"api_key": "test-key"},
                headers=auth_headers["admin"]
            )
                
            assert response.status_code == 200
            data = response.json()
                
#Verify all required fields are present
            assert "status" in data
            assert "message" in data
            assert "error_type" in data
                
#Verify field types
            assert isinstance(data["status"], str)
            assert isinstance(data["message"], str)
            assert data["error_type"] is None or isinstance(data["error_type"], str)
                
#Verify status values
            assert data["status"] in ["success", "error"]

    def test_case_insensitive_provider_names(self, client, auth_headers):
        """Test that provider names are handled case-insensitively"""
        provider_variants = [
            ("openai", "OpenAI"),
            ("anthropic", "ANTHROPIC"), 
            ("google", "Google"),
            ("deepinfra", "DeepInfra")
        ]
        
        for lower_provider, variant_provider in provider_variants:
            with patch.object(user_api_key_service, 'validate_api_key', 
                            return_value=(True, "Success", "success")):
#Test with lowercase (should work)
                response = client.post(
                    f"/api/users/api-keys/{lower_provider}/test",
                    json={"api_key": "test-key"},
                    headers=auth_headers["admin"]
                )
            assert response.status_code == 200
                    
#The actual case sensitivity is handled in the validation logic,
#not the endpoint routing, so we mainly test that standard providers work