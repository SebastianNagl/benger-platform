class TestEnhancedApiKeyEndpoints:
    """Test enhanced API key endpoints with structured error responses"""

    def test_test_user_api_key_success(self, client, auth_headers):
        """Test successful API key test"""
            with patch.object(user_api_key_service, 'validate_api_key', 
                        return_value=(True, "Connection to OpenAI successful", "success")):
        response = client.post(
                "/api/users/api-keys/openai/test",
                json={"api_key": "sk-test-key"},
                headers=auth_headers["admin"]
            )
            
            assert response.status_code == 200
            data = response.json()
            assert data["status"] == "success"
            assert data["message"] == "Connection to OpenAI successful"
            assert data["error_type"] is None

    def test_test_user_api_key_auth_error(self, client, auth_headers):
        """Test API key test with authentication error"""
            with patch.object(user_api_key_service, 'validate_api_key', 
                        return_value=(False, "Invalid API key - please check your OpenAI key", "auth")):
        response = client.post(
                "/api/users/api-keys/openai/test",
                json={"api_key": "invalid-key"},
                headers=auth_headers["admin"]
            )
            
            assert response.status_code == 200
            data = response.json()
            assert data["status"] == "error"
            assert data["message"] == "Invalid API key - please check your OpenAI key"
            assert data["error_type"] == "auth"

