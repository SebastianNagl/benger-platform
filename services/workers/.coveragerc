# Workers coverage config. Unlike the API there is no thread concurrency here
# (Celery handlers are tested by direct call, not through a threadpool), so the
# default tracer measures everything. The key fix vs. the old pytest.ini
# [coverage:run] block (which coverage.py ignored) is omitting test files so we
# measure REAL source coverage (issue #33) — counting tests had inflated the
# branch number to ~84% while real source was ~65%.
[run]
branch = True
source = .
omit =
    tests/*
    */tests/*
    conftest.py
    */conftest.py
    */alembic/*
    */migrations/*
    # one-shot CLI script, exercised by running not unit tests
    parse_existing_generations.py

[report]
show_missing = True
precision = 2
skip_empty = True
# Exclude the genuinely-untestable Celery orchestration tasks in tasks.py
# (issue #33, "optimal solution" decision). These four are chord/chord-callback
# bodies that need a real DB + Celery broker + threadpool + downloaded models +
# object storage to execute — integration-test territory, not unit-testable.
# Their guard/early-return branches are covered by the unit suites; the bodies
# are excluded so the floor reflects real testable coverage. A def-line regex
# excludes the whole function block.
exclude_also =
    def run_evaluation\(
    def evaluate_generation_cell\(
    def evaluate_annotation_cell\(
    def finalize_evaluation_run\(
