# Workers Service Environment Configuration
# Dev defaults. Copy to .env and edit. Never use these values in production.

# =============================================================================
# Environment Identity
# =============================================================================
ENVIRONMENT=development
PYTHONUNBUFFERED=1

# =============================================================================
# Database Configuration (for worker database access)
# =============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=dev-password-123
POSTGRES_DB=benger
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URI=postgresql://postgres:dev-password-123@db:5432/benger

# =============================================================================
# Redis Configuration (Primary for workers)
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=dev-redis-123
REDIS_URI=redis://:dev-redis-123@redis:6379/0

# =============================================================================
# Celery Configuration (Core worker functionality)
# =============================================================================
CELERY_BROKER_URL=redis://:dev-redis-123@redis:6379/0
CELERY_RESULT_BACKEND=redis://:dev-redis-123@redis:6379/0
WORKER_CONCURRENCY=2

# =============================================================================
# Email Configuration (for workers sending emails)
# =============================================================================
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=dev-console-output
SMTP_PASSWORD=dev-console-output
EMAIL_FROM_ADDRESS=noreply@what-a-benger.net
EMAIL_FROM_NAME=BenGER Platform
SENDGRID_API_KEY=

# =============================================================================
# Logging Configuration
# =============================================================================
LOG_LEVEL=DEBUG

# =============================================================================
# API Connection (for worker-to-API communication)
# =============================================================================
API_BASE_URL=http://api:8000

# LLM provider API keys (OPENAI_API_KEY, ANTHROPIC_API_KEY, GOOGLE_API_KEY,
# DEEPINFRA_API_KEY) are configured per-organization in the app UI, not here.
