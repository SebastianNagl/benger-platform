@article{hufeld2024,
  title = {{Jede Korrektur eine andere Note: Quantitative Untersuchung der Objektivit\"at juristischer Klausurbewertungen}},
  shorttitle = {{Jede Korrektur eine andere Note}},
  author = {Hufeld, Clemens},
  year = 2024,
  journal = {Zeitschrift f\"ur Didaktik der Rechtswissenschaft},
  volume = {11},
  number = {1},
  pages = {59--83},
  issn = {2196-7261},
  doi = {10.5771/2196-7261-2024-1-59},
  urldate = {2026-04-02},
  abstract = {In einem Experiment wurden dieselben 15 Anf\"angerklausuren von 23 Personen insgesamt 230 Mal korrigiert. Jede Klausur hat entweder 15 oder 16 Benotungen bekommen, jede Note von einer anderen Person. Die Unterschiede wurden statistisch analysiert, mit dem Ergebnis, dass die durchschnittliche Abweichung zwischen niedrigster und h\"ochster gegebener Note bei 6,47 liegt und statistisch erwartbar nur 42\% der vergebenen Noten pro Klausur \textpm 1 um den Durchschnitt liegen. Theoretisch werden juristische Pr\"ufungen als psychometrischer Test begriffen und das Strukturgleichungsmodell des juristischen Staatsexamens um die latente Variable ,,juristisches K\"onnen`` wird beschrieben. Das Experiment untersucht das erste der drei Hauptg\"utekriterien psychometrischer Tests -- die Objektivit\"at.},
  langid = {ngerman}
}

